# ===== CHOCO HUB BACKUP SERVER =====
# Tất cả các biến dưới đây là bắt buộc.
# Đặt file này cùng thư mục với backup.py (chocohub/Backup/.env)

# Cổng chạy Flask server
BACKUP_PORT=3001

# Token xác thực (phải khớp với BACKUP_TOKEN bên main server)
BACKUP_TOKEN=chocohub-default-token

# URL của main server (để gửi snapshot về khi main online trở lại)
MAIN_SERVER_URL=https://chocohub-r011.onrender.com

# Khoảng thời gian (giây) giữa các lần kiểm tra main server
CHECK_INTERVAL=10

# Đường dẫn file SQLite lưu snapshot
BACKUP_DB_PATH=backup.db
