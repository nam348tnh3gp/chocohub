# ===== MAIN SERVER CONFIG =====
PORT=3000
JWT_SECRET=your_super_secret_random_string_here
NODE_ENV=production

# ===== BACKUP SYNC (kết nối tới backup server) =====
# Định dạng: "token@host:port" (nhiều server cách nhau dấu phẩy)
# Để trống nếu không dùng backup
BACKUP_SERVERS=chocohub-default-token@localhost:3001

# Token mặc định dùng chung nếu không khai báo riêng trong BACKUP_SERVERS
BACKUP_TOKEN=chocohub-default-token
