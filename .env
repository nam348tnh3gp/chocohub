# ===== MAIN SERVER =====
PORT=3000
JWT_SECRET=your_super_secret_random_string_here
NODE_ENV=production

# ===== BACKUP SYNC (nhiều server) =====
# Cú pháp: tokenA@host1:port,tokenB@host2:port
# Nếu cùng token, bạn có thể bỏ token phía trước và đặt BACKUP_TOKEN mặc định
BACKUP_SERVERS=https://hesitant-unroasted-chatroom.ngrok-free.dev

# Token mặc định dùng cho server không có @token riêng (tuỳ chọn, nhưng nên có)
BACKUP_TOKEN=chocohub-default-token
